@page
@model Web.Pages.Vehiculos.EliminarModel
@{
}

<h1>ELiminar Vehículo</h1>

<div class="container">
    <form method="post">
    <div class="col-md-8">
        <div class="card">
            <div class="" card-body">
                <h5 class="card-title>@Html.DisplayFor(modelo => modelo.vehiculo.Marca) @Html.DisplayFor(modelo => modelo.vehiculo.Modelo)</h5>
                <p class="card-text">
                    <div>
                        <b>@Html.DisplayNameFor(modelo => modelo.vehiculo.Placa): @Html.DisplayFor(modelo => modelo.vehiculo.Placa)</b>
                        <b>@Html.DisplayNameFor(modelo => modelo.vehiculo.Anio): @Html.DisplayFor(modelo => modelo.vehiculo.Anio)</b>
                        <b>@Html.DisplayNameFor(modelo => modelo.vehiculo.Precio): @Html.DisplayFor(modelo => modelo.vehiculo.Precio)</b>
                    </div>
                <p class="card-text"><small class="text-muted"> @Html.DisplayFor(modelo => modelo.vehiculo.CorreoPropietario)</small>
                <p class="card-text">
                    <small class="text-muted"> @Html.DisplayFor(modelo => modelo.vehiculo.TelefonoPropietario)</small>
                </p>
            </div>
        </div>
        <a type="button" class="btn btn-primary" asp-page="./Index">Regresar</a>
        <button type="submit" class=" btn btn-danger">Eliminar</button>>
        </form>
    </div>
